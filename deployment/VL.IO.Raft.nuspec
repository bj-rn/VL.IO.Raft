<?xml version="1.0"?>
<package xmlns="http://schemas.microsoft.com/packaging/2011/10/nuspec.xsd">
  <metadata>
    <id>VL.IO.Raft</id>
    <version>1.0.0</version>
    <title>VL.IO.Raft</title>
    <authors>bj-rn</authors>
    <owners>bj-rn</owners>
    <projectUrl>https://github.com/bj-rn/VL.IO.Raft</projectUrl>
    <repository type="git" url="https://github.com/bj-rn/VL.IO.Raft.git" />
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <description>A vvvv gamma library for distributed leader election using the Raft consensus algorithm.</description>
    <tags>VL, vvvv, gamma, raft, consensus, leader election, dotnext</tags>
    <license type="expression">MIT</license>
    <readme>docs\README.md</readme>
    <dependencies>
      <dependency id="DotNext.Net.Cluster" version="5.22.0" />
    </dependencies>
  </metadata>
  <files>
    <file src="..\lib\**\*.dll" target="lib\" exclude="" />
    <file src="..\lib\**\*.xml" target="lib\" exclude="" />
    <file src="..\*.vl" target="" exclude="" />
    <file src="..\help\**" target="help\" exclude="" />
    <file src="..\README.md" target="docs\" />
  </files>
</package>
